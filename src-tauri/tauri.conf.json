{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Francois",
  "version": "0.1.0",
  "identifier": "com.francois.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "francois · session orchestrator",
        "width": 1360,
        "height": 864,
        "minWidth": 1080,
        "minHeight": 700,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
